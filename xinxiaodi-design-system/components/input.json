{
  "slug": "input",
  "name": "输入框 Input",
  "schemaVersion": 1,
  "description": "注册/登录页输入组件，48px 高，支持前缀/后缀/验证码等变体",
  "variantDimensions": [
    {
      "axis": "type",
      "values": ["基础输入框", "带前缀(区号)", "带后缀(验证码)", "密码(显示/隐藏)"]
    },
    {
      "axis": "state",
      "values": ["未输入(empty)", "已输入(filled)", "focus", "error", "disabled"]
    }
  ],
  "representativeVariants": [
    "基础-empty",
    "基础-filled",
    "验证码-可点击",
    "验证码-倒计时",
    "区号-empty"
  ],
  "anatomy": {
    "parts": ["container", "prefix", "input-field", "suffix", "placeholder"],
    "required": ["container", "input-field"]
  },
  "specs": {
    "container": {
      "height": "48px",
      "width": "303px",
      "radius": "4px",
      "border": "1px solid #E5E6EB",
      "backgroundColor": "#FFFFFF",
      "padding": "0 12px"
    },
    "input-field": {
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "22px",
      "color": "#1D2129"
    },
    "placeholder": {
      "color": "#C9CDD4",
      "fontSize": "14px"
    },
    "prefix": {
      "height": "48px",
      "padding": "0 12px",
      "backgroundColor": "#F7F8FA",
      "border": "1px solid #E5E6EB",
      "borderRight": "none",
      "borderRadius": "4px 0 0 4px",
      "fontSize": "14px",
      "color": "#1D2129"
    },
    "suffix-action": {
      "height": "48px",
      "padding": "0 12px",
      "border": "1px solid #E5E6EB",
      "borderLeft": "none",
      "borderRadius": "0 4px 4px 0",
      "fontSize": "12px",
      "activeColor": "#00AAA6",
      "disabledColor": "#7C8492"
    }
  },
  "interaction": {
    "focus": {
      "borderColor": "#00AAA6",
      "boxShadow": "0 0 0 2px rgba(0,170,166,0.1)"
    },
    "blur": {
      "borderColor": "#E5E6EB",
      "boxShadow": "none"
    },
    "验证码倒计时": {
      "duration": "60s",
      "activeText": "发送验证码",
      "activeColor": "#00AAA6",
      "countingText": "{n}s后重新发送",
      "countingColor": "#7C8492",
      "cursor": "not-allowed"
    }
  },
  "usageHints": [
    "输入框用于注册/登录页",
    "focus 时边框变品牌色 + 外发光",
    "placeholder 用 #C9CDD4(gray-4)，不用 text-2",
    "验证码按钮点击后启动 60s 倒计时",
    "区号前缀使用灰底(#F7F8FA)区分"
  ],
  "doNotInvent": [
    "圆角大于 4px 的输入框",
    "彩色边框输入框(focus 除外)",
    "填充色/深色背景输入框",
    "多行 textarea(当前设计系统无此组件)"
  ]
}
