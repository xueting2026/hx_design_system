{
  "$meta": {
    "name": "信小递司机端",
    "version": "1.0.0",
    "description": "信小递司机端微信小程序设计系统 Token，基于 Figma 设计稿整理。设计宽度 375px（iPhone X）。",
    "platform": "微信小程序（移动端）",
    "basis": "海信集团物流司机端——简洁实用、操作效率优先、信息层级清晰",
    "principles": [
      "品牌绿为核心，克制使用色彩",
      "卡片圆角 + 灰阶层差构建层级",
      "内容优先、操作效率优先",
      "间距 4px 基础刻度，节奏感统一",
      "禁用态 = 40% 透明度，不改背景色"
    ],
    "designWidth": "375px",
    "fontFamily": "PingFang SC"
  },
  "color": {
    "primary": {
      "$description": "品牌主色梯度，三层递进",
      "vi-1": {
        "$value": "#E6F7F6",
        "$description": "浅色按钮背景、浅色选中态底色"
      },
      "vi-2": {
        "$value": "#00AAA6",
        "$description": "品牌主色：按钮、链接、选中态图标、Tab 选中背景"
      },
      "vi-3": {
        "$value": "#009093",
        "$description": "按钮 hover/active 态"
      }
    },
    "text": {
      "$description": "文字四级（按信息层级递减）",
      "text-1": {
        "$value": "#BFC5CC",
        "$description": "placeholder 暗提示、搜索框提示文字（最弱，仅用于 placeholder）"
      },
      "text-2": {
        "$value": "#7C8492",
        "$description": "辅助文字、次要信息、标签说明"
      },
      "text-3": {
        "$value": "#1D2129",
        "$description": "主文字、标题、已输入内容（最强）"
      }
    },
    "border": {
      "$description": "线条分两级",
      "border-1": {
        "$value": "#E5E6EB",
        "$description": "分割线、卡片分隔、输入框边框"
      },
      "border-2": {
        "$value": "#BFC5CC",
        "$description": "辅助线条、虚线框、搜索框内分割线"
      }
    },
    "background": {
      "$description": "背景色三层：灰底→白面→灰底（层级递进）",
      "bg-1": {
        "$value": "#F3F5F7",
        "$description": "页面背景、卡片内嵌内容区"
      },
      "bg-2": {
        "$value": "#EBEDF0",
        "$description": "预改约底部区域（仅限特定场景）"
      },
      "white": {
        "$value": "#FFFFFF",
        "$description": "卡片背景、输入框背景"
      }
    },
    "subcolor": {
      "$description": "辅助色承载业务含义，不可随意替换",
      "blue": {
        "$value": "#3491FA",
        "$description": "蓝色标签（提货点/运单状态/整单甩单）"
      },
      "orange": {
        "$value": "#FF7D00",
        "$description": "橙色标签（2C/收货点）、约定时间"
      },
      "purple": {
        "$value": "#722ED1",
        "$description": "紫色标签（电商补货）"
      }
    },
    "danger": {
      "$description": "警告色，仅用于真实风险/错误",
      "danger-1": {
        "$value": "#EE0A24",
        "$description": "错误提示、告警文字、必传提醒"
      },
      "danger-bg": {
        "$value": "#FDE7E9",
        "$description": "告警提示条背景色"
      }
    },
    "neutral": {
      "$description": "中性灰，用于选择器和清除按钮",
      "gray-4": {
        "$value": "#C9CDD4",
        "$description": "清除按钮背景、禁用文字"
      },
      "gray-5": {
        "$value": "#C8C9CC",
        "$description": "checkbox/radio 未选中边框"
      }
    },
    "interaction": {
      "$description": "交互态填充",
      "button-light-bg": {
        "$value": "rgba(0,170,166,0.1)",
        "$description": "浅色大按钮背景"
      }
    },
    "gradient": {
      "$description": "渐变色",
      "header": {
        "$value": "linear-gradient(90deg, #00B7AC 0%, #009B97 100%)",
        "$description": "首页顶部渐变区域"
      },
      "logo": {
        "$value": "linear-gradient(135deg, #57E8DF, #00AAA6)",
        "$description": "Logo 渐变色"
      },
      "floating-button": {
        "$value": "linear-gradient(135deg, #00AAA6, #009B97)",
        "$description": "浮动按钮渐变"
      },
      "scan-entry": {
        "$value": "linear-gradient(90deg, #F4FFFD 0%, #FFFFFF 100%)",
        "$description": "扫码接单入口渐变背景"
      }
    }
  },
  "typography": {
    "$description": "PingFang SC 为唯一字体家族，11 个语义样式",
    "fontFamily": "'PingFang SC', -apple-system, sans-serif",
    "styles": {
      "page-title": {
        "fontSize": "16px",
        "fontWeight": 500,
        "lineHeight": "22px",
        "color": "{color.text.text-3}",
        "$description": "页面标题、导航栏标题"
      },
      "card-title": {
        "fontSize": "14px",
        "fontWeight": 600,
        "lineHeight": "20px",
        "color": "{color.text.text-3}",
        "$description": "卡片标题行"
      },
      "body-emphasis": {
        "fontSize": "14px",
        "fontWeight": 500,
        "lineHeight": "20px",
        "color": "{color.text.text-3}",
        "$description": "正文中需要强调的信息"
      },
      "body": {
        "fontSize": "12px",
        "fontWeight": 500,
        "lineHeight": "18px",
        "color": "{color.text.text-3}",
        "$description": "一般正文内容（默认）"
      },
      "secondary": {
        "fontSize": "12px",
        "fontWeight": 400,
        "lineHeight": "18px",
        "color": "{color.text.text-2}",
        "$description": "辅助说明文字"
      },
      "caption": {
        "fontSize": "10px",
        "fontWeight": 400,
        "lineHeight": "14px",
        "color": "{color.text.text-2}",
        "$description": "次要信息、时间、标签文字"
      },
      "button-large": {
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": "22px",
        "$description": "大按钮文字（40px 高按钮内）"
      },
      "button-small": {
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": "20px",
        "$description": "小按钮、搜索框内文字（32px 高按钮内）"
      },
      "tag": {
        "fontSize": "10px",
        "fontWeight": 400,
        "lineHeight": "14px",
        "$description": "标签组件文字"
      },
      "dialog-title": {
        "fontSize": "18px",
        "fontWeight": 500,
        "lineHeight": "24px",
        "$description": "弹窗标题"
      },
      "dialog-desc": {
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": "20px",
        "color": "{color.text.text-2}",
        "$description": "弹窗描述文字"
      }
    }
  },
  "spacing": {
    "$description": "4px 基础刻度，间距为首要分隔手段",
    "base": "4px",
    "scale": {
      "1": { "$value": "4px", "$description": "紧凑行距、图标与文字" },
      "2": { "$value": "8px", "$description": "标准行距、同组元素间" },
      "3": { "$value": "12px", "$description": "卡片间距、按钮间距" },
      "4": { "$value": "16px", "$description": "页面边距、卡片内边距" },
      "6": { "$value": "24px", "$description": "区块间距" },
      "8": { "$value": "32px", "$description": "大区间距" }
    }
  },
  "radius": {
    "$description": "圆角保持克制，一个视图内保持统一家族",
    "xs": { "$value": "2px", "$description": "标签" },
    "sm": { "$value": "4px", "$description": "按钮、输入框、Tab、搜索框" },
    "md": { "$value": "10px", "$description": "卡片" },
    "lg": { "$value": "12px", "$description": "图标背景" },
    "full": { "$value": "50%", "$description": "头像、浮窗按钮" },
    "pill": { "$value": "58px", "$description": "展开/收起按钮 pill 形状" }
  },
  "shadow": {
    "$description": "阴影仅用于卡片容器和浮层，非静置装饰",
    "card": {
      "$value": "0px 4px 12px rgba(0,0,0,0.05)",
      "$description": "卡片容器"
    },
    "popover": {
      "$value": "0 4px 16px rgba(0,0,0,0.12)",
      "$description": "浮窗弹出层、更多菜单"
    },
    "floating-button": {
      "$value": "0px 4px 12px rgba(0,170,166,0.3)",
      "$description": "浮动按钮（品牌色阴影）"
    }
  },
  "layout": {
    "$description": "页面布局尺寸（设计稿 375px 基准）。demo 模式用固定 375px，开发交付模式改为响应式（宽度 100% + max-width，px×2=rpx）",
    "designWidth": "375px",
    "contentWidth": "343px",
    "pageMargin": "16px",
    "statusBarHeight": "44px",
    "navBarHeight": "44px",
    "headerGradientHeight": "194px",
    "rpxConversion": "开发交付时: px值 × 2 = rpx值"
  },
  "components": {
    "button-primary-large": {
      "height": "40px",
      "width": "303px",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.primary.vi-2}",
      "hoverBackground": "{color.primary.vi-3}",
      "textColor": "{color.background.white}",
      "typography": "{typography.styles.button-large}",
      "padding": "0 119px",
      "disabledTextOpacity": 0.4
    },
    "button-light-large": {
      "height": "40px",
      "width": "303px",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.interaction.button-light-bg}",
      "textColor": "{color.primary.vi-2}",
      "typography": "{typography.styles.button-large}",
      "padding": "6px 16px"
    },
    "button-clear-large": {
      "height": "40px",
      "width": "303px",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.background.bg-2}",
      "textColor": "{color.text.text-3}",
      "typography": "{typography.styles.button-large}"
    },
    "button-primary-small": {
      "height": "32px",
      "width": "auto",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.primary.vi-2}",
      "hoverBackground": "{color.primary.vi-3}",
      "textColor": "{color.background.white}",
      "typography": "{typography.styles.button-small}",
      "padding": "6px 8px",
      "disabledTextOpacity": 0.4
    },
    "button-light-small": {
      "height": "32px",
      "width": "auto",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.primary.vi-1}",
      "textColor": "{color.primary.vi-2}",
      "typography": "{typography.styles.button-small}",
      "padding": "6px 8px"
    },
    "button-text-small": {
      "height": "32px",
      "width": "auto",
      "radius": "{radius.sm}",
      "backgroundColor": "transparent",
      "textColor": "{color.primary.vi-2}",
      "typography": "{typography.styles.button-small}",
      "padding": "6px 8px"
    },
    "input-register": {
      "height": "48px",
      "width": "303px",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.background.white}",
      "borderColor": "{color.border.border-1}",
      "focusBorderColor": "{color.primary.vi-2}",
      "textColor": "{color.text.text-3}",
      "placeholderColor": "{color.neutral.gray-4}",
      "typography": "{typography.styles.body-emphasis}",
      "padding": "0 12px"
    },
    "searchbox": {
      "height": "36px",
      "radius": "{radius.sm}",
      "backgroundColor": "{color.background.white}",
      "textColor": "{color.text.text-3}",
      "placeholderColor": "{color.text.text-1}",
      "typography": "{typography.styles.button-small}",
      "padding": "0 8px 0 4px",
      "queryButton": {
        "height": "28px",
        "backgroundColor": "{color.primary.vi-2}",
        "textColor": "{color.background.white}",
        "radius": "{radius.sm}",
        "padding": "0 12px"
      },
      "clearButton": {
        "size": "16px",
        "backgroundColor": "{color.neutral.gray-4}",
        "iconColor": "{color.background.white}",
        "radius": "{radius.full}"
      },
      "filterLabel": {
        "fontSize": "12px",
        "color": "{color.primary.vi-2}"
      },
      "filterDivider": {
        "width": "1px",
        "height": "16px",
        "color": "{color.border.border-2}"
      }
    },
    "card": {
      "width": "343px",
      "radius": "{radius.md}",
      "backgroundColor": "{color.background.white}",
      "shadow": "{shadow.card}",
      "padding": "12px 16px",
      "border": "1px solid #F2F3F5"
    },
    "tag-status": {
      "height": "20px",
      "radius": "{radius.xs}",
      "borderWidth": "1px",
      "typography": "{typography.styles.tag}",
      "padding": "0 4px",
      "variants": {
        "blue": { "borderColor": "{color.subcolor.blue}", "textColor": "{color.subcolor.blue}" },
        "orange": { "borderColor": "{color.subcolor.orange}", "textColor": "{color.subcolor.orange}" },
        "purple": { "borderColor": "{color.subcolor.purple}", "textColor": "{color.subcolor.purple}" },
        "green": { "borderColor": "{color.primary.vi-2}", "textColor": "{color.primary.vi-2}" }
      }
    },
    "checkbox": {
      "size": "16px",
      "radius": "2px",
      "unchecked": {
        "borderColor": "{color.neutral.gray-5}",
        "borderWidth": "0.8px",
        "backgroundColor": "{color.background.white}"
      },
      "checked": {
        "backgroundColor": "{color.primary.vi-2}",
        "iconColor": "{color.background.white}"
      },
      "disabled": {
        "backgroundColor": "{color.background.bg-2}",
        "borderColor": "{color.neutral.gray-5}"
      },
      "indeterminate": {
        "backgroundColor": "{color.primary.vi-2}",
        "lineColor": "{color.background.white}"
      }
    },
    "radio": {
      "size": "16px",
      "radius": "{radius.full}",
      "unchecked": {
        "borderColor": "{color.border.border-2}",
        "borderWidth": "1.5px",
        "backgroundColor": "{color.background.white}"
      },
      "checked": {
        "backgroundColor": "{color.primary.vi-2}",
        "iconColor": "{color.background.white}"
      }
    },
    "tab": {
      "height": "30px",
      "radius": "{radius.sm}",
      "gap": "8px",
      "typography": "{typography.styles.button-small}",
      "active": {
        "backgroundColor": "{color.primary.vi-2}",
        "textColor": "{color.background.white}"
      },
      "inactive": {
        "backgroundColor": "{color.background.white}",
        "textColor": "{color.text.text-3}"
      }
    },
    "floating-button": {
      "size": "60px",
      "radius": "{radius.full}",
      "background": "{color.gradient.floating-button}",
      "shadow": "{shadow.floating-button}",
      "smallSize": "40px"
    },
    "dialog": {
      "width": "320px",
      "backgroundColor": "{color.background.white}",
      "padding": "24px",
      "shadow": "0 4px 24px rgba(0,0,0,0.15)",
      "overlay": "rgba(0,0,0,0.5)",
      "closeButton": {
        "size": "24px",
        "position": "top 8px right 8px"
      },
      "title": "{typography.styles.dialog-title}",
      "description": "{typography.styles.dialog-desc}",
      "primaryButton": {
        "height": "40px",
        "backgroundColor": "{color.primary.vi-2}",
        "radius": "{radius.sm}"
      },
      "secondaryButton": {
        "height": "40px",
        "backgroundColor": "{color.interaction.button-light-bg}",
        "radius": "{radius.sm}"
      },
      "formInput": {
        "height": "32px",
        "borderColor": "{color.border.border-2}",
        "radius": "{radius.sm}",
        "fontSize": "12px"
      }
    },
    "location-bar": {
      "height": "48px",
      "backgroundColor": "{color.background.bg-1}",
      "iconSize": "16px",
      "addressFont": "{typography.styles.body}",
      "actionColor": "{color.primary.vi-2}",
      "actionFont": "12px"
    },
    "scan-entry": {
      "height": "48px",
      "radius": "{radius.sm}",
      "background": "{color.gradient.scan-entry}",
      "titleFont": "16px bold",
      "subtitleFont": "12px",
      "subtitleColor": "{color.primary.vi-2}"
    },
    "divider": {
      "height": "0.5px",
      "color": "{color.border.border-1}",
      "variants": ["full", "center-inset-16", "left-inset-16", "with-text"]
    },
    "button-group": {
      "$description": "卡片底部按钮组规范",
      "buttonHeight": "32px",
      "buttonGap": "8px",
      "moreLabel": {
        "typography": "{typography.styles.button-small}",
        "color": "{color.primary.vi-2}",
        "background": "transparent"
      },
      "rules": {
        "withStats": {
          "maxButtons": 3,
          "$description": "有「x单x件」统计文字时，右侧操作按钮≤3个"
        },
        "withoutStats": {
          "maxButtons": 5,
          "$description": "无统计文字时，右侧操作按钮≤5个"
        }
      },
      "morePopup": {
        "backgroundColor": "{color.background.white}",
        "radius": "8px",
        "shadow": "{shadow.popover}",
        "padding": "8px 0",
        "itemPadding": "8px 16px",
        "itemFont": "{typography.styles.button-small}"
      }
    }
  },
  "icon": {
    "$description": "SVG 矢量图标，按尺寸分层，支持多色变体",
    "sizes": {
      "jingang": { "$value": "48px", "$description": "金刚区图标（首页功能入口）" },
      "lg": { "$value": "24px", "$description": "通用图标（搜索/关闭/拍照/密码）" },
      "md": { "$value": "20px", "$description": "工具图标（排序/筛选/时间）" },
      "sm": { "$value": "16px", "$description": "辅助图标（定位/电话/复制）" },
      "xs": { "$value": "12px", "$description": "select 箭头" }
    },
    "colorVariants": ["gray", "green", "white", "black"],
    "naming": "{功能}_{颜色}_{尺寸}px.svg",
    "path": "assets/icons/"
  },
  "animation": {
    "$description": "动效克制，服务反馈不表演",
    "duration": {
      "fast": "0.15s",
      "base": "0.2s",
      "slow": "0.25s"
    },
    "easing": "ease",
    "disabledOpacity": 0.4
  },
  "pageTypes": {
    "$description": "信小递六种标准页型",
    "auth": {
      "name": "登录页",
      "$description": "身份认证，不承载业务信息"
    },
    "home": {
      "name": "首页",
      "$description": "概览待办任务，快速跳转各业务模块",
      "modules": ["待到库", "待提货", "待发运", "待打卡", "待派送", "待运抵", "待签收", "回单上传", "送货交接", "历史记录", "服务反馈", "拖车业务", "异常提报", "订单管理"],
      "icons": "assets/shortcuts/icon/home/driver/ 和 assets/shortcuts/icon/home/oa/"
    },
    "function-hub": {
      "name": "功能选择页",
      "$description": "子功能≥3个时作为二级入口集合"
    },
    "list": {
      "name": "列表页",
      "$description": "同类任务集合，支持筛选/搜索/批量操作（最核心页型）"
    },
    "action": {
      "name": "操作页",
      "$description": "针对特定对象录入信息并确认提交"
    },
    "dialog-panel": {
      "name": "弹窗/面板",
      "$description": "轻量级操作（≤2步），不需要独立页面"
    }
  },
  "cardUsageMap": {
    "$description": "卡片组件在各功能模块中的使用规则",
    "运单卡片": {
      "usedIn": "列表页",
      "modules": ["待到库", "待提货", "待发运", "待打卡", "待派送", "待运抵", "待签收"],
      "note": "各模块字段差异见 card.json 的 moduleConfig"
    },
    "物流信息卡片": {
      "usedIn": "列表页",
      "modules": ["订单管理"],
      "note": "管理端订单管理列表页使用"
    },
    "签收管理卡片": {
      "usedIn": "操作页",
      "modules": ["待签收"],
      "note": "待签收操作页面中显示，含图片上传和拒收原因选择"
    }
  }
}