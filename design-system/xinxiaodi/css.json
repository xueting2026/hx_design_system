{
  "$description": "信小递 CSS Token 结构化表示，用于程序化消费。与 ui.css 中的 CSS 变量一一对应。三层结构：primitive → semantic → legacy 别名。",
  "version": "1.1.0",
  "primitive": {
    "primary": {
      "--primary-1": "#E8FFFB", "--primary-2": "#ADEEE4", "--primary-3": "#79DDD1", "--primary-4": "#4ACCC1", "--primary-5": "#22BBB3",
      "--primary-6": "#00AAA6", "--primary-7": "#009093", "--primary-8": "#00757B", "--primary-9": "#005C64", "--primary-10": "#00444D"
    },
    "gray": {
      "--gray-1": "#F7F8FA", "--gray-2": "#F2F3F5", "--gray-3": "#E5E6EB", "--gray-4": "#C9CDD4", "--gray-5": "#A9AEB8",
      "--gray-6": "#86909C", "--gray-7": "#6B7785", "--gray-8": "#4E5969", "--gray-9": "#272E3B", "--gray-10": "#1D2129"
    },
    "red": {
      "--red-1": "#FFECE8", "--red-2": "#FDCDC5", "--red-3": "#FBACA3", "--red-4": "#F98981", "--red-5": "#F76560",
      "--red-6": "#F53F3F", "--red-7": "#CB272D", "--red-8": "#A1151E", "--red-9": "#770813", "--red-10": "#4D000A"
    },
    "orange": {
      "--orange-1": "#FFF7E8", "--orange-2": "#FFE4BA", "--orange-3": "#FFCF8B", "--orange-4": "#FFB65D", "--orange-5": "#FF9A2E",
      "--orange-6": "#FF7D00", "--orange-7": "#D25F00", "--orange-8": "#A64500", "--orange-9": "#792E00", "--orange-10": "#4D1B00"
    },
    "green": {
      "--green-1": "#E8FFEA", "--green-2": "#AFF0B5", "--green-3": "#7BE188", "--green-4": "#4CD263", "--green-5": "#23C343",
      "--green-6": "#00B42A", "--green-7": "#009A29", "--green-8": "#008026", "--green-9": "#006622", "--green-10": "#004D1C"
    },
    "arcoblue": {
      "--arcoblue-1": "#E8F3FF", "--arcoblue-2": "#BEDAFF", "--arcoblue-3": "#94BFFF", "--arcoblue-4": "#6AA1FF", "--arcoblue-5": "#4080FF",
      "--arcoblue-6": "#165DFF", "--arcoblue-7": "#0E42D2", "--arcoblue-8": "#072CA6", "--arcoblue-9": "#031A79", "--arcoblue-10": "#000D4D"
    },
    "purple": {
      "--purple-1": "#F5E8FF", "--purple-2": "#DDBEF6", "--purple-3": "#C396ED", "--purple-4": "#A871E3", "--purple-5": "#8D4EDA",
      "--purple-6": "#722ED1", "--purple-7": "#551DB0", "--purple-8": "#3C108F", "--purple-9": "#27066E", "--purple-10": "#16004D"
    },
    "spacing": {
      "--space-1": "4px", "--space-2": "8px", "--space-3": "12px", "--space-4": "16px", "--space-5": "20px",
      "--space-6": "24px", "--space-7": "28px", "--space-8": "32px", "--space-10": "40px", "--space-12": "48px"
    }
  },
  "semantic": {
    "brand": {
      "--brand": "var(--primary-6)", "--brand-hover": "var(--primary-5)", "--brand-active": "var(--primary-7)",
      "--brand-bg": "var(--primary-1)", "--brand-bg-subtle": "rgba(0,170,166,0.1)", "--brand-focus-ring": "rgba(0,170,166,0.1)"
    },
    "text": {
      "--color-text-1": "#1D2129 (强调/正文标题)", "--color-text-2": "#4E5969 (次强调正文)",
      "--color-text-3": "#86909C (辅助/次要信息)", "--color-text-4": "#C9CDD4 (占位符/置灰)", "--color-white": "#FFFFFF"
    },
    "border": {
      "--color-border-1": "#F2F3F5 (浅)", "--color-border-2": "#E5E6EB (一般)", "--color-border-3": "#C9CDD4 (深)", "--color-border-4": "#86909C (重)"
    },
    "fill": {
      "--color-fill-white": "#FFFFFF", "--color-fill-1": "#F7F8FA", "--color-fill-2": "#F2F3F5", "--color-fill-3": "#E5E6EB", "--color-fill-4": "#C9CDD4", "--color-fill-5": "#4E5969"
    },
    "bg": {
      "--bg-page": "var(--color-fill-2)", "--bg-container": "#FFFFFF", "--bg-container-inset": "var(--color-fill-2)", "--bg-mask": "rgba(0,0,0,0.5)"
    },
    "status": {
      "--success": "#00B42A", "--success-bg": "#E8FFEA", "--warning": "#FF7D00", "--warning-bg": "#FFF7E8",
      "--danger": "#F53F3F", "--danger-bg-2": "#FFECE8", "--info": "#165DFF", "--info-bg": "#E8F3FF"
    },
    "subcolor": {
      "--subcolor-blue": "var(--arcoblue-6)", "--subcolor-orange": "var(--orange-6)", "--subcolor-purple": "var(--purple-6)", "--subcolor-green": "var(--primary-6)"
    },
    "spacing": {
      "--inset-xs": "8px", "--inset-sm": "12px", "--inset-md": "16px", "--inset-lg": "24px",
      "--stack-xs": "4px", "--stack-sm": "8px", "--stack-md": "12px", "--stack-lg": "16px", "--stack-xl": "24px",
      "--inline-xs": "4px", "--inline-sm": "8px", "--inline-md": "12px",
      "--gap-list": "12px", "--gap-section": "24px"
    },
    "radius": {
      "--radius-tag": "2px", "--radius-control": "4px", "--radius-card": "10px", "--radius-icon-bg": "12px",
      "--radius-dialog": "8px", "--radius-pill": "999px", "--radius-circle": "50%"
    },
    "shadow": {
      "--shadow-card": "0px 4px 12px rgba(0,0,0,0.05)", "--shadow-popover": "0 4px 16px rgba(0,0,0,0.12)",
      "--shadow-dialog": "0 4px 24px rgba(0,0,0,0.15)", "--shadow-float": "0px 4px 12px rgba(0,170,166,0.3)"
    },
    "state": { "--disabled-opacity": "0.4" }
  },
  "legacyAliases": {
    "$description": "1.0.0 旧变量名，指向 1.1.0 新值。存量原型继续可用，新代码请用 semantic 变量。",
    "--vi-1": "var(--primary-1)", "--vi-2": "var(--primary-6)", "--vi-3": "var(--primary-7)",
    "--text-1": "var(--color-text-4)", "--text-2": "var(--color-text-3)", "--text-3": "var(--color-text-1)",
    "--border-1": "var(--color-border-2)", "--border-2": "var(--color-border-3)",
    "--bg-1": "var(--color-fill-2)", "--bg-2": "var(--color-fill-3)", "--white": "#FFFFFF",
    "--blue": "var(--subcolor-blue)", "--orange": "var(--subcolor-orange)", "--purple": "var(--subcolor-purple)",
    "--danger-1": "var(--danger)", "--danger-bg": "var(--danger-bg-2)",
    "--radius-xs": "var(--radius-tag)", "--radius-sm": "var(--radius-control)", "--radius-md": "var(--radius-card)", "--radius-lg": "var(--radius-icon-bg)", "--radius-full": "var(--radius-circle)"
  },
  "layout": {
    "--page-width": "375px", "--content-width": "343px", "--page-margin": "16px", "--statusbar-h": "44px", "--navbar-h": "44px"
  },
  "animation": {
    "--duration-fast": "0.15s", "--duration-base": "0.2s", "--duration-slow": "0.25s", "--easing": "ease"
  },
  "textStyles": {
    ".text-page-title": { "fontSize": "16px", "fontWeight": 500, "lineHeight": "22px", "color": "var(--text-3)" },
    ".text-card-title": { "fontSize": "14px", "fontWeight": 600, "lineHeight": "20px", "color": "var(--text-3)" },
    ".text-body-emphasis": { "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px", "color": "var(--text-3)" },
    ".text-body": { "fontSize": "12px", "fontWeight": 500, "lineHeight": "18px", "color": "var(--text-3)" },
    ".text-secondary": { "fontSize": "12px", "fontWeight": 400, "lineHeight": "18px", "color": "var(--text-2)" },
    ".text-caption": { "fontSize": "10px", "fontWeight": 400, "lineHeight": "14px", "color": "var(--text-2)" },
    ".text-button-lg": { "fontSize": "16px", "fontWeight": 400, "lineHeight": "22px" },
    ".text-button-sm": { "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px" },
    ".text-tag": { "fontSize": "10px", "fontWeight": 400, "lineHeight": "14px" },
    ".text-number": { "fontFamily": "var(--font-family-num)", "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px", "fontVariantNumeric": "tabular-nums" }
  },
  "components": {
    ".btn": "按钮基础类",
    ".btn--lg": "大按钮 40px（默认整行 width:100%，padding 0 16px）",
    ".btn--md": "中按钮 36px（width:auto，padding 0 12px）",
    ".btn--sm": "小按钮 32px（width:auto，padding 0 8px）",
    ".btn--primary": "深色按钮",
    ".btn--light": "浅色半透明按钮",
    ".btn--light-solid": "浅色实底按钮(brand-bg)",
    ".btn--clear": "清除按钮",
    ".btn--text": "文字按钮",
    ".btn--disabled": "禁用态",
    ".btn--block": "全宽按钮",
    ".input": "输入框（width:100%）",
    ".input-group": "输入框组（width:100%）",
    ".searchbox": "搜索框",
    ".checkbox": "多选框",
    ".radio": "单选框",
    ".tag": "标签",
    ".card": "卡片（width:100% + max-width 内容宽度）",
    ".tabs": "Tab 容器",
    ".tab-item": "Tab 项",
    ".dialog-overlay": "弹窗蒙层",
    ".dialog": "弹窗容器",
    ".location-bar": "定位栏",
    ".scan-entry": "扫码接单入口",
    ".divider": "分割线",
    ".fab": "浮动按钮",
    ".btn-group": "按钮组",
    ".page": "页面容器"
  }
}
