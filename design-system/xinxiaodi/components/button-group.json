{
  "slug": "button-group",
  "name": "按钮组 Button Group",
  "schemaVersion": 1,
  "figmaNode": "7617:39024 (有统计), 7617:38796 (无统计)",
  "description": "卡片底部操作区按钮组，根据左侧是否有统计文字决定按钮数量上限",
  "variantDimensions": [
    {
      "axis": "layout",
      "values": ["有统计文字(with-stats)", "无统计文字(without-stats)", "有统计+状态标签(with-stats-label)"]
    }
  ],
  "representativeVariants": [
    "with-stats-更多+2按钮",
    "without-stats-更多+4按钮"
  ],
  "anatomy": {
    "parts": [
      "container",
      "stats-label(左侧统计,可选)",
      "more-button(更多文字按钮,溢出时显示)",
      "more-popup(浮窗菜单)",
      "action-buttons(操作按钮组)"
    ],
    "required": ["container", "action-buttons"]
  },
  "specs": {
    "container": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between 或 flex-end",
      "padding": "12px 16px",
      "gap": "8px"
    },
    "stats-label": {
      "fontSize": "12px",
      "fontWeight": 500,
      "color": "#7C8492",
      "lineHeight": "20px",
      "example": "22单65件"
    },
    "action-button": {
      "height": "32px",
      "backgroundColor": "#00AAA6",
      "radius": "4px",
      "padding": "6px 8px",
      "fontSize": "14px",
      "fontWeight": 400,
      "color": "#FFFFFF",
      "lineHeight": "20px"
    },
    "more-button": {
      "fontSize": "14px",
      "fontWeight": 400,
      "color": "#00AAA6",
      "lineHeight": "20px",
      "background": "transparent",
      "cursor": "pointer"
    },
    "more-popup": {
      "backgroundColor": "#FFFFFF",
      "radius": "8px",
      "shadow": "0 4px 16px rgba(0,0,0,0.12)",
      "padding": "8px 0",
      "minWidth": "100px",
      "position": "absolute",
      "bottom": "calc(100% + 8px)",
      "zIndex": 10,
      "item": {
        "padding": "8px 16px",
        "fontSize": "14px",
        "color": "#1D2129",
        "lineHeight": "20px",
        "whiteSpace": "nowrap",
        "cursor": "pointer",
        "hoverBackground": "#E8F8F7"
      }
    }
  },
  "rules": {
    "有统计文字": {
      "maxVisibleButtons": 3,
      "layout": "左侧统计 + 右侧按钮组",
      "overflow": "超过 3 个时，第 2 个按钮左侧显示「更多」"
    },
    "无统计文字": {
      "maxVisibleButtons": 5,
      "layout": "全部右对齐",
      "overflow": "超过 5 个时，第 4 个按钮左侧显示「更多」"
    },
    "有统计+状态标签": {
      "maxVisibleButtons": 3,
      "layout": "左侧: 统计文字(12px Medium #7C8492) + 下方状态标签(border 0.5px #EE0A24, radius 2px, 10px Medium #EE0A24) | 右侧: 按钮组",
      "overflow": "同有统计文字规则",
      "$description": "统计文字和状态标签组成一个 flex-column frame，与右侧按钮 space-between 对齐"
    }
  },
  "interaction": {
    "more-click": "点击「更多」弹出浮窗菜单",
    "more-toggle": "再次点击关闭浮窗",
    "outside-click": "点击外部区域关闭浮窗",
    "button-hover": "background → #009093",
    "button-active": "scale(0.95)"
  },
  "usageHints": [
    "按钮间距固定 8px",
    "所有操作按钮统一使用小按钮样式(32px, #00AAA6)",
    "「更多」是纯文字按钮(#00AAA6, 无底色)",
    "浮窗弹出方向向上（bottom 定位），避免被底部遮挡",
    "一组内按钮样式统一，不混用深色/浅色"
  ],
  "doNotInvent": [
    "按钮组内混用不同颜色按钮",
    "超过限制数量仍全部显示（必须用更多收起）",
    "浮窗向下弹出",
    "「更多」按钮带底色",
    "统计文字放在右侧"
  ],
  "usageScenarios": [
    { "scenario": "卡片底部操作按钮组", "variant": "with-stats-更多+2按钮", "when": "卡片底部左侧带统计文字（如 22单65件），右侧展示按钮组（≤3个）" },
    { "scenario": "卡片底部操作按钮组（无统计）", "variant": "without-stats-更多+4按钮", "when": "无统计文字时按钮全部右对齐（≤5个）" },
    { "scenario": "更多浮窗", "variant": "with-stats-更多+2按钮", "when": "按钮数量超过上限时，用「更多」文字按钮收起，点击向上弹出浮窗菜单" }
  ],
  "states": [
    { "state": "default", "trigger": "默认", "class": "btn-group btn-group--between（浮窗隐藏 .btn-group__popup）" },
    { "state": "more-open", "trigger": "点击「更多」", "class": "btn-group__popup--open（向上弹出浮窗）" },
    { "state": "popup-item-hover", "trigger": "悬停浮窗项", "class": "btn-group__popup-item（:hover 背景 #E8F8F7）" }
  ],
  "cssClasses": ["btn-group", "btn-group--between", "btn-group--end", "btn-group__stats", "btn-group__more", "btn-group__popup", "btn-group__popup--open", "btn-group__popup-item"],
  "exampleRefs": ["examples/demo-list.html", "examples/demo-pending-arrival.html", "preview/component-button.html"]
}
