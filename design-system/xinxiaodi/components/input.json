{
  "slug": "input",
  "name": "输入框 Input",
  "schemaVersion": 1,
  "description": "注册/登录页输入组件，48px 高，支持前缀/后缀/验证码等变体",
  "variantDimensions": [
    {
      "axis": "type",
      "values": ["基础输入框", "带前缀(区号)", "带后缀(验证码)", "密码(显示/隐藏)"]
    },
    {
      "axis": "state",
      "values": ["未输入(empty)", "已输入(filled)", "focus", "error", "disabled"]
    }
  ],
  "representativeVariants": [
    "基础-empty",
    "基础-filled",
    "验证码-可点击",
    "验证码-倒计时",
    "区号-empty"
  ],
  "anatomy": {
    "parts": ["container", "prefix", "input-field", "suffix", "placeholder"],
    "required": ["container", "input-field"]
  },
  "specs": {
    "container": {
      "height": "48px",
      "widthMode": "block",
      "widthNote": "width:100%，由父容器（内容区 343px）控制上限，不写死像素宽（1.0.0 的 width:303px 已废弃）",
      "radius": "var(--radius-control) / 4px",
      "border": "1px solid #E5E6EB",
      "borderToken": "color-border-2",
      "backgroundColor": "#FFFFFF",
      "padding": "0 12px"
    },
    "input-field": {
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "22px",
      "color": "#1D2129"
    },
    "placeholder": {
      "color": "#C9CDD4",
      "fontSize": "14px"
    },
    "prefix": {
      "height": "48px",
      "padding": "0 12px",
      "backgroundColor": "#F7F8FA",
      "border": "1px solid #E5E6EB",
      "borderRight": "none",
      "borderRadius": "4px 0 0 4px",
      "fontSize": "14px",
      "color": "#1D2129"
    },
    "suffix-action": {
      "height": "48px",
      "padding": "0 12px",
      "border": "1px solid #E5E6EB",
      "borderLeft": "none",
      "borderRadius": "0 4px 4px 0",
      "fontSize": "12px",
      "activeColor": "#00AAA6",
      "disabledColor": "#7C8492"
    }
  },
  "interaction": {
    "focus": {
      "borderColor": "#00AAA6",
      "boxShadow": "0 0 0 2px rgba(0,170,166,0.1)"
    },
    "blur": {
      "borderColor": "#E5E6EB",
      "boxShadow": "none"
    },
    "验证码倒计时": {
      "duration": "60s",
      "activeText": "发送验证码",
      "activeColor": "#00AAA6",
      "countingText": "{n}s后重新发送",
      "countingColor": "#7C8492",
      "cursor": "not-allowed"
    }
  },
  "usageHints": [
    "输入框用于注册/登录页",
    "focus 时边框变品牌色 + 外发光",
    "placeholder 用 #C9CDD4(gray-4)，不用 text-2",
    "验证码按钮点击后启动 60s 倒计时",
    "区号前缀使用灰底(#F7F8FA)区分"
  ],
  "doNotInvent": [
    "圆角大于 4px 的输入框",
    "彩色边框输入框(focus 除外)",
    "填充色/深色背景输入框",
    "多行 textarea(当前设计系统无此组件)"
  ],
  "usageScenarios": [
    { "scenario": "手机号/验证码登录", "variant": "验证码-可点击 / 验证码-倒计时", "when": "登录页录入手机号并获取验证码，点击后进入 60s 倒计时" },
    { "scenario": "区号前缀输入", "variant": "区号-empty", "when": "需要区号前缀的手机号输入，前缀用灰底区分" },
    { "scenario": "基础文本录入", "variant": "基础-empty / 基础-filled", "when": "注册/登录页普通文本字段" }
  ],
  "states": [
    { "state": "empty", "trigger": "默认未输入", "class": "input（placeholder #C9CDD4）" },
    { "state": "focus", "trigger": "聚焦", "class": "input（:focus 边框 vi-2 + 外发光 rgba(0,170,166,0.1)）" },
    { "state": "error", "trigger": "校验失败", "class": "input--error（配合 .input-error-msg）" },
    { "state": "disabled", "trigger": "禁用", "class": "input--disabled" },
    { "state": "countdown", "trigger": "验证码倒计时中", "class": "input-group__suffix--disabled（cursor not-allowed，文字 #7C8492）" }
  ],
  "cssClasses": ["input", "input--error", "input--disabled", "input-error-msg", "input-group", "input-group__prefix", "input-group__suffix", "input-group__suffix--disabled"],
  "exampleRefs": ["examples/login.html", "preview/component-input.html"]
}
