{
  "slug": "navigation",
  "name": "导航 Navigation",
  "schemaVersion": 1,
  "figmaNode": "971:42748 (定位组件)",
  "description": "导航相关组件集合：定位栏、扫码接单入口、展开收起按钮",
  "variantDimensions": [
    {
      "axis": "component",
      "values": ["定位栏(location-bar)", "扫码接单入口(scan-entry)"]
    }
  ],
  "subComponents": {
    "location-bar": {
      "figmaNode": "971:42748",
      "description": "48px 高定位栏，左侧绿色 pin 图标 + 地址文字 + 右侧操作按钮",
      "variantDimensions": [
        {
          "axis": "type",
          "values": ["地址", "地址+1(筛选)", "地址+2(最新+筛选)", "地址+3(最新+切换+筛选)"]
        },
        {
          "axis": "state",
          "values": ["off(未选中)", "on(选中)"]
        }
      ],
      "specs": {
        "container": {
          "width": "375px",
          "height": "48px",
          "backgroundColor": "#F3F5F7",
          "padding": "0 16px",
          "display": "flex",
          "alignItems": "center",
          "gap": "2px"
        },
        "pin-icon": {
          "size": "16px",
          "source": "assets/icons/position_green_16px.svg"
        },
        "address": {
          "fontSize": "12px",
          "color": "#1D2129",
          "lineHeight": "20px",
          "overflow": "ellipsis",
          "whiteSpace": "nowrap"
        },
        "action-button": {
          "height": "24px",
          "padding": "0 8px",
          "radius": "4px",
          "fontSize": "12px",
          "color": "#00AAA6",
          "onBackground": "#FFFFFF"
        },
        "arrow-icon": {
          "size": "12px",
          "off": "down_surface_green_12px.svg",
          "on": "up_surface_green_12px.svg"
        }
      },
      "interaction": {
        "action-click": "切换 on/off 状态，箭头方向翻转",
        "hover": "按钮出现白底",
        "筛选按钮": "点击后高亮（白色底），再次点击取消"
      }
    },
    "scan-entry": {
      "description": "48px 高扫码接单/退出扫码入口，渐变背景",
      "specs": {
        "container": {
          "width": "343px",
          "height": "48px",
          "radius": "4px",
          "padding": "0 12px",
          "display": "flex",
          "alignItems": "center"
        },
        "variants": {
          "扫码接单": {
            "background": "linear-gradient(90deg, #F4FFFD 0%, #FFFFFF 100%)",
            "icon": "assets/icons/scan_receive_green.svg",
            "title": "扫码接单",
            "titleFont": "16px bold #1D2129",
            "subtitle": "扫码领取配送任务",
            "subtitleFont": "12px #00AAA6"
          },
          "退出扫码": {
            "background": "linear-gradient(90deg, #FFF9F4 0%, #FFFFFF 100%)",
            "icon": "assets/icons/scan_receive_orange.svg",
            "title": "退出扫码",
            "titleFont": "16px bold #1D2129",
            "subtitle": "无（退出扫码无副标题）"
          }
        },
        "icon": {
          "size": "32px",
          "note": "icon svg 自带渐变圆底（scan_receive_green / scan_receive_orange），直接使用无需额外圆形背景"
        },
        "right-arrow": {
          "size": "16px",
          "color": "#C8C9CC",
          "path": "M6 4l4 4-4 4"
        }
      }
    }
  },
  "usageHints": [
    "定位栏出现在列表页顶部（标题栏下方）",
    "扫码接单入口：绿色=扫码接单（副标题「扫码领取配送任务」），橙色=退出扫码（无副标题）",
    "扫码接单入口仅在待到库/待办中心列表页使用",
    "定位栏宽度始终 375px（满屏），不受内容区 343px 限制",
    "展开/收起按钮属于卡片组件（card），不在导航组件内"
  ],
  "doNotInvent": [
    "垂直方向的导航组件",
    "底部 Tab 导航（小程序有自带）",
    "面包屑导航",
    "定位栏内添加搜索功能"
  ],
  "usageScenarios": [
    { "scenario": "定位筛选", "variant": "location-bar", "when": "列表页顶部（标题栏下方）展示当前定位地址 + 最新/切换/筛选操作" },
    { "scenario": "扫码接单入口", "variant": "scan-entry-扫码接单(绿)", "when": "待到库/待办中心列表页，扫码领取配送任务（副标题「扫码领取配送任务」）" },
    { "scenario": "退出扫码", "variant": "scan-entry-退出扫码(橙)", "when": "已进入扫码模式时提供退出入口（无副标题）" }
  ],
  "states": [
    { "state": "location-off", "trigger": "定位栏筛选未选中", "class": "location-bar__action（箭头向下，无白底）" },
    { "state": "location-on", "trigger": "定位栏筛选选中", "class": "location-bar__action--active（白底高亮，箭头向上）" },
    { "state": "scan-green", "trigger": "扫码接单入口", "class": "scan-entry scan-entry--green（配合 .scan-entry__icon--green）" },
    { "state": "scan-orange", "trigger": "退出扫码入口", "class": "scan-entry scan-entry--orange（配合 .scan-entry__icon--orange）" }
  ],
  "cssClasses": ["location-bar", "location-bar__icon", "location-bar__address", "location-bar__action", "location-bar__action--active", "location-bar__action-text", "scan-entry", "scan-entry--green", "scan-entry--orange", "scan-entry__icon", "scan-entry__icon--green", "scan-entry__icon--orange", "scan-entry__content", "scan-entry__title", "scan-entry__subtitle", "scan-entry__arrow"],
  "exampleRefs": ["examples/demo-home.html", "examples/demo-list.html", "preview/component-navigation.html"]
}
