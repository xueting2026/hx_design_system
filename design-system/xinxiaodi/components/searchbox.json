{
  "slug": "searchbox",
  "name": "搜索框 Search Box",
  "schemaVersion": 1,
  "figmaNode": "7618:39222",
  "description": "36px 高搜索框组件，白色背景，圆角 4px。三种类型：默认/有筛选/多项筛选",
  "variantDimensions": [
    {
      "axis": "type",
      "values": ["默认(default)", "有筛选(with-filter)", "多项筛选(with-sort-filter)"]
    },
    {
      "axis": "state",
      "values": ["空(empty)", "输入中(typing)", "有值(filled)"]
    }
  ],
  "representativeVariants": [
    "default-empty",
    "with-filter-empty",
    "with-sort-filter-empty",
    "default-filled"
  ],
  "anatomy": {
    "parts": [
      "container",
      "filter-dropdown",
      "filter-divider",
      "search-icon",
      "input-field",
      "clear-button",
      "query-button",
      "sort-button",
      "filter-button"
    ],
    "required": ["container", "search-icon", "input-field", "query-button"]
  },
  "specs": {
    "container": {
      "height": "36px",
      "backgroundColor": "#FFFFFF",
      "radius": "4px",
      "paddingLeft": "8px",
      "paddingRight": "4px",
      "display": "flex",
      "alignItems": "center",
      "gap": "8px"
    },
    "search-icon": {
      "size": "24px",
      "source": "assets/icons/search_gray_24px.svg"
    },
    "input-field": {
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "22px",
      "color": "#1D2129",
      "placeholderColor": "#BFC5CC",
      "border": "none",
      "background": "transparent",
      "flex": 1
    },
    "query-button": {
      "height": "28px",
      "padding": "0 12px",
      "backgroundColor": "#00AAA6",
      "radius": "4px",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "22px",
      "color": "#FFFFFF"
    },
    "clear-button": {
      "size": "16px",
      "backgroundColor": "#C9CDD4",
      "radius": "50%",
      "iconColor": "#FFFFFF",
      "display": "none (输入内容后显示)"
    },
    "filter-dropdown": {
      "fontSize": "12px",
      "color": "#00AAA6",
      "arrowIcon": "down_surface_green_12px.svg",
      "menu": {
        "backgroundColor": "#FFFFFF",
        "radius": "8px",
        "shadow": "0 4px 16px rgba(0,0,0,0.12)",
        "padding": "8px 0",
        "minWidth": "120px",
        "itemPadding": "8px 16px",
        "itemFontSize": "14px",
        "itemColor": "#1D2129"
      }
    },
    "filter-divider": {
      "width": "1px",
      "height": "16px",
      "color": "#BFC5CC"
    },
    "sort-button": {
      "size": "36px",
      "iconSize": "20px",
      "iconSource": "assets/icons/sort_green_20px.svg",
      "labelFontSize": "10px",
      "labelColor": "#00AAA6"
    },
    "filter-button": {
      "size": "36px",
      "iconSize": "20px",
      "iconSource": "assets/icons/screen_green_20px.svg",
      "labelFontSize": "10px",
      "labelColor": "#00AAA6"
    }
  },
  "interaction": {
    "clear-button": "输入内容后显示，点击清空输入并隐藏",
    "filter-dropdown": "点击展开下拉菜单，选择后收起并更新标签文字",
    "sort-button": "点击弹出排序选项浮窗",
    "filter-button": "点击弹出筛选选项浮窗",
    "outside-click": "点击组件外部关闭所有浮窗"
  },
  "usageHints": [
    "默认搜索框：无筛选，搜索图标 + 输入 + 查询按钮",
    "有筛选搜索框：左侧筛选下拉 + 分割线 + 搜索输入 + 查询按钮",
    "多项筛选搜索框：搜索框 + 右侧「排序」「筛选」图标按钮",
    "placeholder 用 text-1(#BFC5CC)，不用 text-2",
    "查询按钮始终显示，不因输入状态隐藏"
  ],
  "doNotInvent": [
    "圆角大于 4px 的搜索框",
    "搜索框内的品牌色背景",
    "将排序/筛选按钮放在搜索框左侧",
    "不带查询按钮的搜索框"
  ],
  "usageScenarios": [
    { "scenario": "搜索框", "variant": "default-empty / default-filled", "when": "列表页关键词搜索运单，搜索图标+输入+查询按钮" },
    { "scenario": "查询项筛选下拉", "variant": "with-filter-empty", "when": "搜索前先选筛选维度（左侧筛选下拉 + 分割线 + 输入）" },
    { "scenario": "排序/筛选图标按钮", "variant": "with-sort-filter-empty", "when": "需要排序和多维筛选时，右侧「排序」「筛选」图标按钮" }
  ],
  "states": [
    { "state": "empty", "trigger": "默认无输入", "class": "searchbox（.searchbox__clear 隐藏）" },
    { "state": "filled", "trigger": "有输入内容", "class": "searchbox__clear--visible（清除按钮显示）" },
    { "state": "filter-open", "trigger": "点击筛选下拉", "class": "searchbox__filter-menu--open（下拉菜单展开）" }
  ],
  "cssClasses": ["searchbox", "searchbox__icon", "searchbox__input", "searchbox__clear", "searchbox__clear--visible", "searchbox__query", "searchbox__query-text", "searchbox__filter", "searchbox__filter-trigger", "searchbox__filter-label", "searchbox__filter-divider", "searchbox__filter-menu", "searchbox__filter-menu--open", "searchbox__filter-item", "searchbox__action", "searchbox__action-icon", "searchbox__action-label"],
  "exampleRefs": ["examples/demo-list.html", "examples/demo-pending-arrival.html", "preview/component-searchbox.html"]
}
