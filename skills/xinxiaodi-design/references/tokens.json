{
  "$meta": {
    "name": "信小递司机端",
    "version": "1.1.0",
    "description": "信小递司机端微信小程序设计系统 Token，基于 Figma 设计稿整理，色彩体系对齐 Pangea Design（品牌色 #00AAA6）。设计宽度 375px（iPhone X）。",
    "platform": "微信小程序（移动端）",
    "basis": "海信集团物流司机端——简洁实用、操作效率优先、信息层级清晰",
    "architecture": {
      "$description": "Token 分三层，逐层引用：primitive（原始值，不直接用于组件）→ semantic（语义别名，按用途命名）→ component（组件专属）。引用语法 {tier.path}。",
      "tiers": ["primitive", "semantic", "component"],
      "rule": "组件与页面只消费 semantic / component 层；primitive 层仅供 semantic 引用，不要在业务代码里直接写 primitive 或 hex。"
    },
    "principles": [
      "品牌绿为核心，克制使用色彩",
      "卡片圆角 + 灰阶层差构建层级",
      "内容优先、操作效率优先",
      "间距 4px 基础刻度，节奏感统一",
      "禁用态 = 40% 透明度，不改背景色",
      "尺寸与宽度解耦：组件只定义高度/内边距，宽度由 block/auto/max-width 决定，不写死像素宽"
    ],
    "designWidth": "375px",
    "fontFamily": "PingFang SC",
    "changelog": {
      "1.1.0": "色彩全面对齐 Pangea（primary/danger/warning/success/info/purple/gray 各 10 级 + 语义层）；Token 重构为 primitive/semantic/component 三层；间距补齐 20/28/40/48 并新增语义间距；圆角新增组件级 token 且 pill 58px→999px（真胶囊）；按钮/输入框/卡片去掉写死像素宽，改用 block/auto/max-width；新增成功/警告/信息状态色与按钮 md 尺寸。旧命名（vi-1/2/3、text-1/2/3 等）保留为兼容别名。"
    }
  },

  "primitive": {
    "$description": "第 1 层：原始值。色板由浅到深 1→10，主色/常规态在第 6 级。仅供 semantic 层引用。",

    "color": {
      "primary": {
        "$description": "品牌色（青绿），常规主色 = primary-6",
        "primary-1": { "$value": "#E8FFFB", "$description": "浅色/白色悬浮" },
        "primary-2": { "$value": "#ADEEE4", "$description": "文字禁用" },
        "primary-3": { "$value": "#79DDD1", "$description": "一般禁用" },
        "primary-4": { "$value": "#4ACCC1", "$description": "特殊场景" },
        "primary-5": { "$value": "#22BBB3", "$description": "悬浮" },
        "primary-6": { "$value": "#00AAA6", "$description": "常规（品牌主色）" },
        "primary-7": { "$value": "#009093", "$description": "点击/按下" },
        "primary-8": { "$value": "#00757B", "$description": "深" },
        "primary-9": { "$value": "#005C64", "$description": "更深" },
        "primary-10": { "$value": "#00444D", "$description": "最深" }
      },
      "gray": {
        "$description": "中性灰，页面背景/文字/线条的原始来源",
        "gray-1": { "$value": "#F7F8FA" },
        "gray-2": { "$value": "#F2F3F5" },
        "gray-3": { "$value": "#E5E6EB" },
        "gray-4": { "$value": "#C9CDD4" },
        "gray-5": { "$value": "#A9AEB8" },
        "gray-6": { "$value": "#86909C" },
        "gray-7": { "$value": "#6B7785" },
        "gray-8": { "$value": "#4E5969" },
        "gray-9": { "$value": "#272E3B" },
        "gray-10": { "$value": "#1D2129" }
      },
      "red": {
        "$description": "危险/错误（danger 语义来源）",
        "red-1": { "$value": "#FFECE8" },
        "red-2": { "$value": "#FDCDC5" },
        "red-3": { "$value": "#FBACA3" },
        "red-4": { "$value": "#F98981" },
        "red-5": { "$value": "#F76560" },
        "red-6": { "$value": "#F53F3F" },
        "red-7": { "$value": "#CB272D" },
        "red-8": { "$value": "#A1151E" },
        "red-9": { "$value": "#770813" },
        "red-10": { "$value": "#4D000A" }
      },
      "orange": {
        "$description": "警告（warning 语义来源）+ 橙色标签（2C/收货点）",
        "orange-1": { "$value": "#FFF7E8" },
        "orange-2": { "$value": "#FFE4BA" },
        "orange-3": { "$value": "#FFCF8B" },
        "orange-4": { "$value": "#FFB65D" },
        "orange-5": { "$value": "#FF9A2E" },
        "orange-6": { "$value": "#FF7D00" },
        "orange-7": { "$value": "#D25F00" },
        "orange-8": { "$value": "#A64500" },
        "orange-9": { "$value": "#792E00" },
        "orange-10": { "$value": "#4D1B00" }
      },
      "green": {
        "$description": "成功（success 语义来源）",
        "green-1": { "$value": "#E8FFEA" },
        "green-2": { "$value": "#AFF0B5" },
        "green-3": { "$value": "#7BE188" },
        "green-4": { "$value": "#4CD263" },
        "green-5": { "$value": "#23C343" },
        "green-6": { "$value": "#00B42A" },
        "green-7": { "$value": "#009A29" },
        "green-8": { "$value": "#008026" },
        "green-9": { "$value": "#006622" },
        "green-10": { "$value": "#004D1C" }
      },
      "arcoblue": {
        "$description": "信息（info 语义来源）+ 蓝色标签（运单状态/提货点）",
        "arcoblue-1": { "$value": "#E8F3FF" },
        "arcoblue-2": { "$value": "#BEDAFF" },
        "arcoblue-3": { "$value": "#94BFFF" },
        "arcoblue-4": { "$value": "#6AA1FF" },
        "arcoblue-5": { "$value": "#4080FF" },
        "arcoblue-6": { "$value": "#165DFF" },
        "arcoblue-7": { "$value": "#0E42D2" },
        "arcoblue-8": { "$value": "#072CA6" },
        "arcoblue-9": { "$value": "#031A79" },
        "arcoblue-10": { "$value": "#000D4D" }
      },
      "purple": {
        "$description": "紫色标签（电商补货）",
        "purple-1": { "$value": "#F5E8FF" },
        "purple-2": { "$value": "#DDBEF6" },
        "purple-3": { "$value": "#C396ED" },
        "purple-4": { "$value": "#A871E3" },
        "purple-5": { "$value": "#8D4EDA" },
        "purple-6": { "$value": "#722ED1" },
        "purple-7": { "$value": "#551DB0" },
        "purple-8": { "$value": "#3C108F" },
        "purple-9": { "$value": "#27066E" },
        "purple-10": { "$value": "#16004D" }
      },
      "white": { "$value": "#FFFFFF", "$description": "纯白" }
    },

    "spacing": {
      "$description": "间距原始刻度，4px 基础栅格，禁止非 4 倍数值",
      "base": "4px",
      "sp-0": { "$value": "0px" },
      "sp-1": { "$value": "4px" },
      "sp-2": { "$value": "8px" },
      "sp-3": { "$value": "12px" },
      "sp-4": { "$value": "16px" },
      "sp-5": { "$value": "20px" },
      "sp-6": { "$value": "24px" },
      "sp-7": { "$value": "28px" },
      "sp-8": { "$value": "32px" },
      "sp-10": { "$value": "40px" },
      "sp-12": { "$value": "48px" }
    },

    "typography": {
      "$description": "字体原始刻度",
      "fontFamily": {
        "cn": "'PingFang SC', -apple-system, sans-serif",
        "num": "'Nunito Sans', 'PingFang SC', sans-serif"
      },
      "fontSize": {
        "fs-10": { "$value": "10px" },
        "fs-12": { "$value": "12px" },
        "fs-13": { "$value": "13px" },
        "fs-14": { "$value": "14px" },
        "fs-16": { "$value": "16px" },
        "fs-18": { "$value": "18px" },
        "fs-20": { "$value": "20px" },
        "fs-24": { "$value": "24px" }
      },
      "fontWeight": {
        "regular": { "$value": 400 },
        "medium": { "$value": 500 },
        "semibold": { "$value": 600 }
      },
      "lineHeight": {
        "lh-14": { "$value": "14px" },
        "lh-18": { "$value": "18px" },
        "lh-20": { "$value": "20px" },
        "lh-22": { "$value": "22px" },
        "lh-24": { "$value": "24px" },
        "lh-28": { "$value": "28px" },
        "lh-32": { "$value": "32px" }
      },
      "letterSpacing": {
        "normal": { "$value": "0" },
        "num": { "$value": "0.2px", "$description": "数字/英文轻微字距，提升可读性" }
      }
    },

    "radius": {
      "$description": "圆角原始刻度。pill=999px 为真胶囊（与高度无关）",
      "r-2": { "$value": "2px" },
      "r-4": { "$value": "4px" },
      "r-8": { "$value": "8px" },
      "r-10": { "$value": "10px" },
      "r-12": { "$value": "12px" },
      "r-16": { "$value": "16px" },
      "r-pill": { "$value": "999px" },
      "r-full": { "$value": "50%" }
    },

    "shadow": {
      "$description": "阴影原始层级",
      "sd-card": { "$value": "0px 4px 12px rgba(0,0,0,0.05)", "$description": "卡片容器" },
      "sd-popover": { "$value": "0 4px 16px rgba(0,0,0,0.12)", "$description": "浮层/更多菜单" },
      "sd-dialog": { "$value": "0 4px 24px rgba(0,0,0,0.15)", "$description": "弹窗" },
      "sd-float": { "$value": "0px 4px 12px rgba(0,170,166,0.3)", "$description": "浮动按钮（品牌色阴影）" }
    },

    "motion": {
      "duration": {
        "fast": { "$value": "0.15s" },
        "base": { "$value": "0.2s" },
        "slow": { "$value": "0.25s" }
      },
      "easing": { "$value": "ease" }
    }
  },

  "semantic": {
    "$description": "第 2 层：语义别名，按用途命名，引用 primitive。组件与页面优先消费这一层。",

    "color": {
      "brand": {
        "$description": "品牌交互色",
        "default": { "$value": "{primitive.color.primary.primary-6}", "$description": "主色：按钮、链接、选中态、Tab 选中背景" },
        "hover": { "$value": "{primitive.color.primary.primary-5}", "$description": "悬浮" },
        "active": { "$value": "{primitive.color.primary.primary-7}", "$description": "按下/点击" },
        "bg": { "$value": "{primitive.color.primary.primary-1}", "$description": "浅色选中底、浅色实底按钮背景" },
        "bg-subtle": { "$value": "rgba(0,170,166,0.1)", "$description": "半透明浅色按钮/卡片头背景" },
        "focus-ring": { "$value": "rgba(0,170,166,0.1)", "$description": "输入框 focus 外发光" }
      },
      "text": {
        "$description": "文字四级 + 反白（数值对齐 Pangea color-text-1..4）",
        "primary": { "$value": "{primitive.color.gray.gray-10}", "$description": "主文字/标题/已输入内容（原 text-3）" },
        "secondary": { "$value": "{primitive.color.gray.gray-8}", "$description": "次强调正文" },
        "tertiary": { "$value": "{primitive.color.gray.gray-6}", "$description": "辅助/次要信息（原 text-2 近似）" },
        "placeholder": { "$value": "{primitive.color.gray.gray-4}", "$description": "占位符/置灰（原 text-1 近似）" },
        "disabled": { "$value": "{primitive.color.gray.gray-4}", "$description": "禁用文字" },
        "inverse": { "$value": "{primitive.color.white}", "$description": "深底反白文字" }
      },
      "border": {
        "$description": "线条四级（数值对齐 Pangea color-border-1..4）",
        "light": { "$value": "{primitive.color.gray.gray-2}", "$description": "最浅分割线" },
        "default": { "$value": "{primitive.color.gray.gray-3}", "$description": "分割线/卡片分隔/输入框边框（原 border-1）" },
        "strong": { "$value": "{primitive.color.gray.gray-4}", "$description": "辅助线条/虚线框（原 border-2 近似）" },
        "heavy": { "$value": "{primitive.color.gray.gray-6}", "$description": "重/按钮描边" }
      },
      "fill": {
        "$description": "填充/背景（数值对齐 Pangea color-fill-1..5）",
        "white": { "$value": "{primitive.color.white}", "$description": "纯白：卡片/输入框表面" },
        "fill-1": { "$value": "{primitive.color.gray.gray-1}", "$description": "浅/禁用底" },
        "fill-2": { "$value": "{primitive.color.gray.gray-2}", "$description": "常规灰底：页面背景/卡片内嵌区（原 bg-1）" },
        "fill-3": { "$value": "{primitive.color.gray.gray-3}", "$description": "深灰底：预改约底部等特定区域（原 bg-2）" },
        "fill-4": { "$value": "{primitive.color.gray.gray-4}", "$description": "重/清除按钮底" },
        "fill-5": { "$value": "{primitive.color.gray.gray-8}", "$description": "强调/图标" }
      },
      "bg": {
        "$description": "背景语义快捷别名",
        "page": { "$value": "{semantic.color.fill.fill-2}", "$description": "页面背景" },
        "container": { "$value": "{semantic.color.fill.white}", "$description": "卡片/容器表面" },
        "container-inset": { "$value": "{semantic.color.fill.fill-2}", "$description": "卡片内嵌内容区（区别于白底）" },
        "mask": { "$value": "rgba(0,0,0,0.5)", "$description": "弹窗蒙层" }
      },
      "status": {
        "$description": "功能状态色（default = 6 级主色，bg = 1 级浅底）",
        "success": { "default": { "$value": "{primitive.color.green.green-6}" }, "bg": { "$value": "{primitive.color.green.green-1}" } },
        "warning": { "default": { "$value": "{primitive.color.orange.orange-6}" }, "bg": { "$value": "{primitive.color.orange.orange-1}" } },
        "danger": { "default": { "$value": "{primitive.color.red.red-6}" }, "bg": { "$value": "{primitive.color.red.red-1}" } },
        "info": { "default": { "$value": "{primitive.color.arcoblue.arcoblue-6}" }, "bg": { "$value": "{primitive.color.arcoblue.arcoblue-1}" } }
      },
      "subcolor": {
        "$description": "业务标签色，颜色承载语义，不可随意替换",
        "blue": { "$value": "{primitive.color.arcoblue.arcoblue-6}", "$description": "蓝色标签：提货点/运单状态/整单甩单" },
        "orange": { "$value": "{primitive.color.orange.orange-6}", "$description": "橙色标签：2C/收货点、约定时间" },
        "purple": { "$value": "{primitive.color.purple.purple-6}", "$description": "紫色标签：电商补货" },
        "green": { "$value": "{primitive.color.primary.primary-6}", "$description": "绿色标签：品牌态" }
      },
      "gradient": {
        "header": { "$value": "linear-gradient(90deg, #00B7AC 0%, #009B97 100%)", "$description": "首页顶部渐变" },
        "logo": { "$value": "linear-gradient(135deg, #57E8DF, #00AAA6)", "$description": "Logo 渐变" },
        "floating-button": { "$value": "linear-gradient(135deg, #00AAA6, #009B97)", "$description": "浮动按钮渐变" },
        "scan-entry": { "$value": "linear-gradient(90deg, #F4FFFD 0%, #FFFFFF 100%)", "$description": "扫码接单入口渐变" }
      }
    },

    "spacing": {
      "$description": "语义间距：每个用途对应一个刻度，消除一数多用的歧义",
      "inset": {
        "$description": "组件内边距 padding",
        "xs": { "$value": "{primitive.spacing.sp-2}", "$description": "8px：紧凑组件内边距（小标签、小 pill）" },
        "sm": { "$value": "{primitive.spacing.sp-3}", "$description": "12px：卡片竖向内边距、紧凑容器" },
        "md": { "$value": "{primitive.spacing.sp-4}", "$description": "16px：卡片横向内边距、页面边距" },
        "lg": { "$value": "{primitive.spacing.sp-6}", "$description": "24px：弹窗内边距、宽松容器" }
      },
      "stack": {
        "$description": "纵向堆叠间距 gap / margin-bottom",
        "xs": { "$value": "{primitive.spacing.sp-1}", "$description": "4px：行内紧凑（图标与文字、标题与副标题）" },
        "sm": { "$value": "{primitive.spacing.sp-2}", "$description": "8px：同组元素之间" },
        "md": { "$value": "{primitive.spacing.sp-3}", "$description": "12px：卡片列表项之间" },
        "lg": { "$value": "{primitive.spacing.sp-4}", "$description": "16px：小区块之间" },
        "xl": { "$value": "{primitive.spacing.sp-6}", "$description": "24px：大区块之间" }
      },
      "inline": {
        "$description": "横向并排间距 gap",
        "xs": { "$value": "{primitive.spacing.sp-1}", "$description": "4px：图标与文字" },
        "sm": { "$value": "{primitive.spacing.sp-2}", "$description": "8px：按钮之间、Tab 之间" },
        "md": { "$value": "{primitive.spacing.sp-3}", "$description": "12px：并排卡片/控件" }
      },
      "gap": {
        "list": { "$value": "{primitive.spacing.sp-3}", "$description": "12px：卡片列表间距（唯一用途）" },
        "section": { "$value": "{primitive.spacing.sp-6}", "$description": "24px：页面区块之间" }
      },
      "pageMargin": { "$value": "{primitive.spacing.sp-4}", "$description": "16px：页面左右边距（唯一用途）" }
    },

    "radius": {
      "$description": "语义圆角，组件按此引用；同一视图保持统一家族",
      "tag": { "$value": "{primitive.radius.r-2}", "$description": "标签" },
      "control": { "$value": "{primitive.radius.r-4}", "$description": "按钮/输入框/Tab/搜索框" },
      "card": { "$value": "{primitive.radius.r-10}", "$description": "卡片" },
      "icon-bg": { "$value": "{primitive.radius.r-12}", "$description": "图标背景" },
      "dialog": { "$value": "{primitive.radius.r-8}", "$description": "弹窗" },
      "pill": { "$value": "{primitive.radius.r-pill}", "$description": "胶囊（展开/收起、真胶囊按钮）" },
      "circle": { "$value": "{primitive.radius.r-full}", "$description": "头像/浮窗按钮" }
    },

    "typography": {
      "$description": "语义文本样式（保留信小递既有 11 档，新增等宽数字），引用原始刻度",
      "fontFamily": "{primitive.typography.fontFamily.cn}",
      "styles": {
        "page-title": { "fontSize": "16px", "fontWeight": 500, "lineHeight": "22px", "color": "{semantic.color.text.primary}", "$description": "页面标题、导航栏标题" },
        "card-title": { "fontSize": "14px", "fontWeight": 600, "lineHeight": "20px", "color": "{semantic.color.text.primary}", "$description": "卡片标题行" },
        "body-emphasis": { "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px", "color": "{semantic.color.text.primary}", "$description": "正文强调" },
        "body": { "fontSize": "12px", "fontWeight": 500, "lineHeight": "18px", "color": "{semantic.color.text.primary}", "$description": "一般正文（默认）" },
        "secondary": { "fontSize": "12px", "fontWeight": 400, "lineHeight": "18px", "color": "{semantic.color.text.tertiary}", "$description": "辅助说明" },
        "caption": { "fontSize": "10px", "fontWeight": 400, "lineHeight": "14px", "color": "{semantic.color.text.tertiary}", "$description": "次要信息/时间/标签" },
        "button-large": { "fontSize": "16px", "fontWeight": 400, "lineHeight": "22px", "color": "{semantic.color.text.inverse}", "$description": "大按钮文字（40px 按钮内）" },
        "button-medium": { "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px", "color": "{semantic.color.text.inverse}", "$description": "中按钮文字（36px 按钮内）" },
        "button-small": { "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px", "color": "{semantic.color.text.inverse}", "$description": "小按钮/搜索框文字（32px 按钮内）" },
        "tag": { "fontSize": "10px", "fontWeight": 400, "lineHeight": "14px", "$description": "标签组件文字" },
        "dialog-title": { "fontSize": "18px", "fontWeight": 500, "lineHeight": "24px", "$description": "弹窗标题" },
        "dialog-desc": { "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px", "color": "{semantic.color.text.tertiary}", "$description": "弹窗描述" },
        "number": { "fontFamily": "{primitive.typography.fontFamily.num}", "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px", "fontFeature": "tabular-nums", "$description": "等宽数字：运单号/重量/时间，竖排对齐" }
      }
    },

    "elevation": {
      "card": { "$value": "{primitive.shadow.sd-card}" },
      "popover": { "$value": "{primitive.shadow.sd-popover}" },
      "dialog": { "$value": "{primitive.shadow.sd-dialog}" },
      "floating-button": { "$value": "{primitive.shadow.sd-float}" }
    },

    "state": {
      "disabledOpacity": { "$value": 0.4, "$description": "禁用态：仅降文字/图标透明度，不改背景色" }
    },

    "motion": {
      "duration": "{primitive.motion.duration}",
      "easing": "{primitive.motion.easing}"
    }
  },

  "component": {
    "$description": "第 3 层：组件专属 token。尺寸与宽度解耦——size 只定义 height/padding/font，width 由 widthMode（block/auto）决定，不写死像素宽。",

    "button": {
      "$description": "按钮：size(large/medium/small) × style(primary/light/light-solid/clear/text) × state(default/hover/active/disabled)",
      "radius": "{semantic.radius.control}",
      "fontWeight": 400,
      "sizes": {
        "large": { "height": "40px", "paddingX": "16px", "font": "{semantic.typography.styles.button-large}", "defaultWidth": "block", "$description": "页面级主操作，默认整行（width:100%）" },
        "medium": { "height": "36px", "paddingX": "12px", "font": "{semantic.typography.styles.button-medium}", "defaultWidth": "auto" },
        "small": { "height": "32px", "paddingX": "8px", "font": "{semantic.typography.styles.button-small}", "defaultWidth": "auto", "$description": "卡片内操作，内容自适应宽度" }
      },
      "widthModes": {
        "block": "width:100%（撑满父容器，父容器控制宽度上限）",
        "auto": "width:auto（内容宽度 + paddingX），可选 min-width"
      },
      "styles": {
        "primary": {
          "default": { "background": "{semantic.color.brand.default}", "textColor": "{semantic.color.text.inverse}" },
          "hover": { "background": "{semantic.color.brand.active}", "textColor": "{semantic.color.text.inverse}" },
          "active": { "background": "{semantic.color.brand.active}", "textColor": "{semantic.color.text.inverse}" },
          "disabled": { "background": "{semantic.color.brand.default}", "textColor": "{semantic.color.text.inverse}", "opacity": "{semantic.state.disabledOpacity}" }
        },
        "light": {
          "default": { "background": "{semantic.color.brand.bg-subtle}", "textColor": "{semantic.color.brand.default}" },
          "hover": { "background": "rgba(0,170,166,0.18)", "textColor": "{semantic.color.brand.default}" },
          "disabled": { "background": "{semantic.color.brand.bg-subtle}", "textColor": "{semantic.color.brand.default}", "opacity": "{semantic.state.disabledOpacity}" }
        },
        "light-solid": {
          "default": { "background": "{semantic.color.brand.bg}", "textColor": "{semantic.color.brand.default}" },
          "hover": { "background": "#D4F2F1", "textColor": "{semantic.color.brand.default}" }
        },
        "clear": {
          "default": { "background": "{semantic.color.fill.fill-3}", "textColor": "{semantic.color.text.primary}" },
          "hover": { "background": "#E0E2E5", "textColor": "{semantic.color.text.primary}" }
        },
        "text": {
          "default": { "background": "transparent", "textColor": "{semantic.color.brand.default}" }
        }
      },
      "cssClasses": ["btn", "btn--lg", "btn--md", "btn--sm", "btn--primary", "btn--light", "btn--light-solid", "btn--clear", "btn--text", "btn--disabled", "btn--block"]
    },

    "input": {
      "$description": "输入框：默认整行（width:100%），由父容器约束最大宽度；不写死像素宽",
      "height": "48px",
      "widthMode": "block",
      "radius": "{semantic.radius.control}",
      "backgroundColor": "{semantic.color.fill.white}",
      "borderColor": "{semantic.color.border.default}",
      "focusBorderColor": "{semantic.color.brand.default}",
      "focusRing": "{semantic.color.brand.focus-ring}",
      "textColor": "{semantic.color.text.primary}",
      "placeholderColor": "{semantic.color.text.placeholder}",
      "typography": "{semantic.typography.styles.body-emphasis}",
      "padding": "0 12px",
      "prefixBg": "{semantic.color.fill.fill-1}",
      "errorBorderColor": "{semantic.color.status.danger.default}",
      "disabledBg": "{semantic.color.fill.fill-2}"
    },

    "searchbox": {
      "height": "36px",
      "widthMode": "block",
      "radius": "{semantic.radius.control}",
      "backgroundColor": "{semantic.color.fill.white}",
      "textColor": "{semantic.color.text.primary}",
      "placeholderColor": "{semantic.color.text.placeholder}",
      "typography": "{semantic.typography.styles.button-small}",
      "padding": "0 8px 0 4px",
      "queryButton": { "height": "28px", "backgroundColor": "{semantic.color.brand.default}", "textColor": "{semantic.color.text.inverse}", "radius": "{semantic.radius.control}", "padding": "0 12px" },
      "clearButton": { "size": "16px", "backgroundColor": "{semantic.color.fill.fill-4}", "iconColor": "{semantic.color.text.inverse}", "radius": "{semantic.radius.circle}" },
      "filterLabel": { "fontSize": "12px", "color": "{semantic.color.brand.default}" },
      "filterDivider": { "width": "1px", "height": "16px", "color": "{semantic.color.border.strong}" }
    },

    "card": {
      "$description": "卡片：默认 width:100% + max-width 内容宽度(343px)，响应式安全，不写死 343px",
      "widthMode": "block",
      "maxWidth": "{layout.contentWidth}",
      "radius": "{semantic.radius.card}",
      "backgroundColor": "{semantic.color.fill.white}",
      "shadow": "{semantic.elevation.card}",
      "paddingY": "12px",
      "paddingX": "16px",
      "border": "1px solid {semantic.color.border.light}",
      "insetBackground": "{semantic.color.bg.container-inset}"
    },

    "tag-status": {
      "height": "20px",
      "radius": "{semantic.radius.tag}",
      "borderWidth": "1px",
      "typography": "{semantic.typography.styles.tag}",
      "padding": "0 4px",
      "variants": {
        "blue": { "borderColor": "{semantic.color.subcolor.blue}", "textColor": "{semantic.color.subcolor.blue}" },
        "orange": { "borderColor": "{semantic.color.subcolor.orange}", "textColor": "{semantic.color.subcolor.orange}" },
        "purple": { "borderColor": "{semantic.color.subcolor.purple}", "textColor": "{semantic.color.subcolor.purple}" },
        "green": { "borderColor": "{semantic.color.subcolor.green}", "textColor": "{semantic.color.subcolor.green}" },
        "red": { "borderColor": "{semantic.color.status.danger.default}", "textColor": "{semantic.color.status.danger.default}" }
      }
    },

    "checkbox": {
      "size": "16px",
      "radius": "{primitive.radius.r-2}",
      "unchecked": { "borderColor": "{primitive.color.gray.gray-4}", "borderWidth": "0.8px", "backgroundColor": "{semantic.color.fill.white}" },
      "checked": { "backgroundColor": "{semantic.color.brand.default}", "iconColor": "{semantic.color.text.inverse}" },
      "disabled": { "backgroundColor": "{semantic.color.fill.fill-3}", "borderColor": "{primitive.color.gray.gray-4}" },
      "indeterminate": { "backgroundColor": "{semantic.color.brand.default}", "lineColor": "{semantic.color.text.inverse}" }
    },

    "radio": {
      "size": "16px",
      "radius": "{semantic.radius.circle}",
      "unchecked": { "borderColor": "{semantic.color.border.strong}", "borderWidth": "1.5px", "backgroundColor": "{semantic.color.fill.white}" },
      "checked": { "backgroundColor": "{semantic.color.brand.default}", "iconColor": "{semantic.color.text.inverse}" }
    },

    "tab": {
      "height": "30px",
      "radius": "{semantic.radius.control}",
      "gap": "{semantic.spacing.inline.sm}",
      "typography": "{semantic.typography.styles.button-small}",
      "active": { "backgroundColor": "{semantic.color.brand.default}", "textColor": "{semantic.color.text.inverse}" },
      "inactive": { "backgroundColor": "{semantic.color.fill.white}", "textColor": "{semantic.color.text.primary}" }
    },

    "floating-button": {
      "size": "60px",
      "smallSize": "40px",
      "radius": "{semantic.radius.circle}",
      "background": "{semantic.color.gradient.floating-button}",
      "shadow": "{semantic.elevation.floating-button}"
    },

    "dialog": {
      "width": "320px",
      "backgroundColor": "{semantic.color.fill.white}",
      "padding": "{semantic.spacing.inset.lg}",
      "radius": "{semantic.radius.dialog}",
      "shadow": "{semantic.elevation.dialog}",
      "overlay": "{semantic.color.bg.mask}",
      "closeButton": { "size": "24px", "position": "top 8px right 8px" },
      "title": "{semantic.typography.styles.dialog-title}",
      "description": "{semantic.typography.styles.dialog-desc}",
      "primaryButton": { "height": "40px", "backgroundColor": "{semantic.color.brand.default}", "radius": "{semantic.radius.control}" },
      "secondaryButton": { "height": "40px", "backgroundColor": "{semantic.color.brand.bg-subtle}", "radius": "{semantic.radius.control}" },
      "formInput": { "height": "32px", "borderColor": "{semantic.color.border.strong}", "radius": "{semantic.radius.control}", "fontSize": "12px" }
    },

    "location-bar": {
      "height": "48px",
      "backgroundColor": "{semantic.color.bg.page}",
      "iconSize": "16px",
      "addressFont": "{semantic.typography.styles.body}",
      "actionColor": "{semantic.color.brand.default}",
      "actionFont": "12px"
    },

    "scan-entry": {
      "height": "48px",
      "radius": "{semantic.radius.control}",
      "background": "{semantic.color.gradient.scan-entry}",
      "titleFont": "16px bold",
      "subtitleFont": "12px",
      "subtitleColor": "{semantic.color.brand.default}"
    },

    "divider": {
      "height": "0.5px",
      "color": "{semantic.color.border.default}",
      "variants": ["full", "center-inset-16", "left-inset-16", "with-text"]
    },

    "button-group": {
      "$description": "卡片底部按钮组规范",
      "buttonHeight": "32px",
      "buttonGap": "{semantic.spacing.inline.sm}",
      "moreLabel": { "typography": "{semantic.typography.styles.button-small}", "color": "{semantic.color.brand.default}", "background": "transparent" },
      "rules": {
        "withStats": { "maxButtons": 3, "$description": "有「x单x件」统计文字时，右侧操作按钮≤3个" },
        "withoutStats": { "maxButtons": 5, "$description": "无统计文字时，右侧操作按钮≤5个" }
      },
      "morePopup": { "backgroundColor": "{semantic.color.fill.white}", "radius": "{semantic.radius.dialog}", "shadow": "{semantic.elevation.popover}", "padding": "8px 0", "itemPadding": "8px 16px", "itemFont": "{semantic.typography.styles.button-small}" }
    }
  },

  "legacyAliases": {
    "$description": "1.0.0 旧命名 → 1.1.0 新 token 的映射。ui.css 仍导出这些旧 CSS 变量名（指向新值）以兼容存量原型。新代码请用 semantic/component 层。",
    "color": {
      "--vi-1": "{primitive.color.primary.primary-1}",
      "--vi-2": "{primitive.color.primary.primary-6}",
      "--vi-3": "{primitive.color.primary.primary-7}",
      "--text-1": "{semantic.color.text.placeholder}",
      "--text-2": "{semantic.color.text.tertiary}",
      "--text-3": "{semantic.color.text.primary}",
      "--border-1": "{semantic.color.border.default}",
      "--border-2": "{semantic.color.border.strong}",
      "--bg-1": "{semantic.color.fill.fill-2}",
      "--bg-2": "{semantic.color.fill.fill-3}",
      "--white": "{primitive.color.white}",
      "--blue": "{semantic.color.subcolor.blue}",
      "--orange": "{semantic.color.subcolor.orange}",
      "--purple": "{semantic.color.subcolor.purple}",
      "--danger-1": "{semantic.color.status.danger.default}",
      "--danger-bg": "{semantic.color.status.danger.bg}",
      "--gray-4": "{primitive.color.gray.gray-4}",
      "--gray-5": "{primitive.color.gray.gray-4}"
    },
    "note": "存量原型颜色会随之刷新为 Pangea 值（如告警红 #EE0A24→#F53F3F、标签蓝 #3491FA→#165DFF、灰阶微调）。这是本次升级的预期行为。"
  },

  "layout": {
    "$description": "页面布局尺寸（设计稿 375px 基准）。demo 模式用固定 375px，开发交付模式改为响应式（宽度 100% + max-width，px×2=rpx）",
    "designWidth": "375px",
    "contentWidth": "343px",
    "pageMargin": "16px",
    "statusBarHeight": "44px",
    "navBarHeight": "44px",
    "headerGradientHeight": "194px",
    "rpxConversion": "开发交付时: px值 × 2 = rpx值"
  },

  "icon": {
    "$description": "SVG 矢量图标，按尺寸分层，支持多色变体",
    "sizes": {
      "jingang": { "$value": "48px", "$description": "金刚区图标（首页功能入口）" },
      "lg": { "$value": "24px", "$description": "通用图标（搜索/关闭/拍照/密码）" },
      "md": { "$value": "20px", "$description": "工具图标（排序/筛选/时间）" },
      "sm": { "$value": "16px", "$description": "辅助图标（定位/电话/复制）" },
      "xs": { "$value": "12px", "$description": "select 箭头" }
    },
    "colorVariants": ["gray", "green", "white", "black"],
    "naming": "{功能}_{颜色}_{尺寸}px.svg",
    "path": "assets/icons/"
  },

  "animation": {
    "$description": "动效克制，服务反馈不表演（等同 semantic.motion，保留供兼容读取）",
    "duration": { "fast": "0.15s", "base": "0.2s", "slow": "0.25s" },
    "easing": "ease",
    "disabledOpacity": 0.4
  },

  "pageTypes": {
    "$description": "信小递六种标准页型",
    "auth": { "name": "登录页", "$description": "身份认证，不承载业务信息" },
    "home": {
      "name": "首页",
      "$description": "概览待办任务，快速跳转各业务模块",
      "modules": ["待到库", "待提货", "待发运", "待打卡", "待派送", "待运抵", "待签收", "回单上传", "送货交接", "历史记录", "服务反馈", "拖车业务", "异常提报", "订单管理"],
      "icons": "assets/shortcuts/icon/home/driver/ 和 assets/shortcuts/icon/home/oa/"
    },
    "function-hub": { "name": "功能选择页", "$description": "子功能≥3个时作为二级入口集合" },
    "list": { "name": "列表页", "$description": "同类任务集合，支持筛选/搜索/批量操作（最核心页型）" },
    "action": { "name": "操作页", "$description": "针对特定对象录入信息并确认提交" },
    "dialog-panel": { "name": "弹窗/面板", "$description": "轻量级操作（≤2步），不需要独立页面" }
  },

  "cardUsageMap": {
    "$description": "卡片组件在各功能模块中的使用规则",
    "运单卡片": { "usedIn": "列表页", "modules": ["待到库", "待提货", "待发运", "待打卡", "待派送", "待运抵", "待签收"], "note": "各模块字段差异见 card.json 的 moduleConfig" },
    "物流信息卡片": { "usedIn": "列表页", "modules": ["订单管理"], "note": "管理端订单管理列表页使用" },
    "签收管理卡片": { "usedIn": "操作页", "modules": ["待签收"], "note": "待签收操作页面中显示，含图片上传和拒收原因选择" }
  }
}
