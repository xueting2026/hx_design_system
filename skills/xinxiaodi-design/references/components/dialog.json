    { "scenario": "单按钮提示", "variant": "单按钮-确认返回", "when": "仅需用户确认知晓，单个全宽主按钮" },
    { "scenario": "仅标题确认", "variant": "仅标题-确认提交", "when": "简短确认无需描述文字" },
    { "scenario": "表单填写", "variant": "表单-运单发运", "when": "轻量表单录入（≤2步），必填项填完后主按钮激活" }
