{
  "slug": "card",
  "name": "卡片 Card",
  "schemaVersion": 1,
  "figmaNode": "957:34249 (物流卡片), 2053:64264 (签收卡片), 7602:38648 (运单卡片收起), 7602:38443 (运单卡片多选)",
  "description": "信小递核心数据容器，343px 宽，10px 圆角，低阴影。运单卡片是80%列表页都会使用的核心组件。",
  "variantDimensions": [
    {
      "axis": "type",
      "values": ["运单卡片", "签收管理卡片", "物流信息卡片"]
    },
    {
      "axis": "mode",
      "values": ["收起(collapsed)", "展开(expanded)", "多选(checkbox)"]
    }
  ],
  "representativeVariants": [
    "运单卡片-collapsed",
    "运单卡片-expanded",
    "签收管理卡片-collapsed",
    "签收管理卡片-expanded",
    "物流信息卡片-default"
  ],
  "运单卡片结构": {
    "$description": "运单卡片是80%列表页都会涵盖的核心组件，从大框架分为5个部分",
    "parts": [
      {
        "name": "1. 提货/收货信息",
        "description": "卡片顶部区域，展示地点和货品概要",
        "fields": ["提货点/收货点标签(tag)", "提货/收货地址(地址文字，过长省略)", "仓库编号(如 [H2532] 扬州冰箱CDC厂区)", "产品数量摘要(如 海信空调110件(13.0m³)，电视99件(11.0m³))"],
        "layout": "标签+地址同行 → 仓库编号行 → 产品摘要行(灰底pill)",
        "specs": {
          "tag": "提货点=蓝色(#3491FA)边框标签, 收货点=橙色(#FF7D00)边框标签",
          "address": "14px Medium #1D2129, 单行省略(ellipsis)",
          "warehouse": "12px Regular #1D2129",
          "productSummary": "bg #F3F5F7, radius 4px, 10px Regular #7C8492, height 18px"
        }
      },
      {
        "name": "2. 运单信息",
        "description": "调度单分组信息，展示运输相关数据",
        "fields": ["车牌号(如 鲁UN521E)", "运单号(如 D22110100291)", "下达时间(如 2022/11/16 18:00)", "产品数量(如 海信空调30件(1.3m³))"],
        "layout": "车牌+运单号左对齐 + 下达时间右对齐 → 产品摘要行(灰底pill)",
        "specs": {
          "plateAndOrder": "12px Medium #1D2129",
          "time": "10px Regular #7C8492, margin-left: auto",
          "productSummary": "同提货/收货信息中的产品摘要样式"
        }
      },
      {
        "name": "3. 订单信息",
        "description": "展开后显示的订单详情区域(默认收起)",
        "fields": ["SAP单号", "2C/2B标签", "订单号", "收货地址", "导航图标(地址行右侧)", "品类", "型号", "数量", "收货联系人", "收货联系电话", "备注/注释文字", "预约/改约按钮"],
        "layout": {
          "orderTop": "绿色底(rgba(0,170,166,0.1)) + SAP单号 + 2C/2B标签, 高度44px, 顶部圆角4px",
          "alertBar": "告警条(可选): bg #FDE7E9, 10px Medium #EE0A24, 高度22px",
          "orderBody": "灰底(#F3F5F7) padding 12px, 订单号+地址+品类型号数量列表",
          "orderFooter": "bg #EBEDF0, 底部圆角4px, 收货联系人+电话 + 预约按钮"
        },
        "specs": {
          "orderTop": { "background": "rgba(0,170,166,0.1)", "height": "44px", "borderRadius": "4px 4px 0 0" },
          "sapNo": "12px Medium #1D2129",
          "tag2C": "border 1px solid #FF7D00, radius 2px, 11px Medium #FF7D00",
          "orderNo": "10px Regular #1D2129",
          "address": "12px Regular #7C8492 (label) / #1D2129 (value)",
          "productRow": "12px Regular #7C8492, 三列: 品类(50px) | 型号(flex:1) | 数量(36px右对齐)",
          "divider": "0.5px #E5E6EB, margin 6px 0",
          "contactLabel": "12px Medium #7C8492, width 72px",
          "contactValue": "12px Medium #7C8492, 电话色 #00AAA6",
          "appointButton": "bg #00AAA6, radius 4px, padding 4px 8px, 10px white"
        }
      },
      {
        "name": "4. 展开/收起",
        "description": "控制订单信息区域的展开和收起",
        "layout": "居中显示 pill 按钮",
        "specs": {
          "container": "居中, padding 8px 0",
          "pill": "bg #F3F5F7, border 1px solid #E5E6EB, radius 58px, padding 4px 12px, height 26px",
          "text": "12px Regular #1D2129",
          "arrow": "12px, fill #1D2129, transition transform 0.2s"
        },
        "interaction": "点击切换：文字(展开↔收起) + 箭头旋转180deg + 订单信息显隐"
      },
      {
        "name": "5. 按钮组",
        "description": "卡片底部操作区，同按钮组规范(button-group.json)",
        "layout": "左侧统计(x单x件) + 右侧按钮组(右对齐)",
        "specs": {
          "container": "padding 8px 16px 12px, flex space-between",
          "stats": "12px Medium #7C8492(如 '2单6件')",
          "buttons": "参见 button-group.json 规范"
        },
        "rules": "有统计文字时右侧按钮≤3个, 无统计时≤5个, 超出显示「更多」"
      }
    ],
    "dataStructure": "地点分组(提货/收货信息) → 调度单分组(运单信息) → 运单明细(订单信息)。一个提货/收货信息可包含多个运单信息，一个运单信息可包含多个订单信息。",
    "defaultState": "订单信息默认收起，展开后显示完整详情",
    "moduleConfig": {
