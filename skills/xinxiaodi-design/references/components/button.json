{
  "slug": "button",
  "name": "按钮 Button",
  "schemaVersion": 1,
  "figmaNode": "按钮/圆角_solid_40px, 按钮/圆角_solid_32px",
  "description": "信小递按钮组件，分大按钮(40px)和小按钮(32px)两档，各有深色/浅色/清除等风格变体",
  "variantDimensions": [
    {
      "axis": "size",
      "values": ["large-40px", "medium-36px", "small-32px"]
    },
    {
      "axis": "style",
      "values": ["深色(primary)", "浅色(light)", "清除(clear)", "文字(text)"]
    },
    {
      "axis": "state",
      "values": ["正常(default)", "hover", "禁用(disabled)"]
    }
  ],
  "representativeVariants": [
    "large-深色-default",
    "large-浅色-default",
    "large-清除-default",
    "small-深色-default",
    "small-浅色-default",
    "small-文字-default"
  ],
  "anatomy": {
    "parts": ["container", "label"],
    "required": ["container", "label"]
  },
  "sizingModel": {
    "$description": "尺寸与宽度解耦：size 只定义 height/paddingX/font，width 由 widthMode 决定，不写死像素宽（1.0.0 的 width:303px + padding:0 119px 已废弃）。",
    "widthModes": {
      "block": "width:100%，撑满父容器，由父容器（内容区 343px）控制上限 —— 大按钮默认",
      "auto": "width:auto，内容宽度 + paddingX，可选 min-width —— 中/小按钮默认"
    }
  },
  "specs": {
    "large-40px": {
      "height": "40px",
      "widthMode": "block",
      "radius": "var(--radius-control) / 4px",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": "22px",
      "textAlign": "center",
      "paddingX": "16px",
      "cssClass": "btn btn--lg",
      "note": "页面级主操作，默认整行。旧的 width:303px / padding:0 119px 已移除。",
      "variants": {
        "深色-default": { "background": "#00AAA6", "textColor": "#FFFFFF", "token": "brand.default" },
        "深色-hover": { "background": "#009093", "textColor": "#FFFFFF", "token": "brand.active" },
        "深色-disabled": { "background": "#00AAA6", "textColor": "#FFFFFF", "textOpacity": 0.4 },
        "浅色-default": { "background": "rgba(0,170,166,0.1)", "textColor": "#00AAA6", "token": "brand.bg-subtle" },
        "浅色-disabled": { "background": "rgba(0,170,166,0.1)", "textColor": "#00AAA6", "textOpacity": 0.4 },
        "清除-default": { "background": "#E5E6EB", "textColor": "#1D2129", "token": "color-fill-3" }
      }
    },
    "medium-36px": {
      "height": "36px",
      "widthMode": "auto",
      "radius": "var(--radius-control) / 4px",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "20px",
      "textAlign": "center",
      "paddingX": "12px",
      "cssClass": "btn btn--md",
      "note": "1.1.0 新增中号，介于大(页面级)与小(卡片内)之间；可加 .btn--block 变整行。",
      "variants": {
        "深色-default": { "background": "#00AAA6", "textColor": "#FFFFFF", "token": "brand.default" },
        "深色-hover": { "background": "#009093", "textColor": "#FFFFFF", "token": "brand.active" },
        "浅色-default": { "background": "#E8FFFB", "textColor": "#00AAA6", "token": "brand.bg" },
        "文字-default": { "background": "transparent", "textColor": "#00AAA6", "token": "brand.default" }
      }
    },
    "small-32px": {
      "height": "32px",
      "widthMode": "auto",
      "radius": "var(--radius-control) / 4px",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "20px",
      "textAlign": "center",
      "paddingX": "8px",
      "cssClass": "btn btn--sm",
      "note": "卡片内操作，内容自适应宽度。",
      "variants": {
        "深色-default": { "background": "#00AAA6", "textColor": "#FFFFFF", "token": "brand.default" },
        "深色-hover": { "background": "#009093", "textColor": "#FFFFFF", "token": "brand.active" },
        "深色-disabled": { "background": "#00AAA6", "textColor": "#FFFFFF", "textOpacity": 0.4 },
        "浅色-default": { "background": "#E8FFFB", "textColor": "#00AAA6", "token": "brand.bg" },
        "浅色-disabled": { "background": "#E8FFFB", "textColor": "#00AAA6", "textOpacity": 0.4 },
        "文字-default": { "background": "transparent", "textColor": "#00AAA6", "token": "brand.default" }
      }
    }
  },
  "interaction": {
    "hover": "背景切换为 vi-3(#009093)",
    "active": "scale(0.97) 微缩",
    "disabled": "文字/图标 opacity 40%，cursor: not-allowed",
    "transition": "background 0.2s, transform 0.1s"
  },
  "usageHints": [
    "一组操作中只突出一个主按钮（深色），其余用浅色或文字",
    "按钮文字统一 Regular(400) 字重，不用 Medium/Semibold",
    "禁用态只降透明度，不改背景色",
    "大按钮用于页面级主操作（登录、提交）",
    "小按钮用于卡片内操作（扫码到库、分单、审核）",
    "「更多」使用文字按钮（无底色、#00AAA6 文字）"
  ],
  "doNotInvent": [
    "描边/outline 按钮——信小递不存在此变体",
    "渐变按钮——仅浮动按钮使用渐变",
    "pill 圆角按钮——按钮统一 4px 圆角",
    "阴影按钮——静置无阴影",
    "不同字重——按钮统一 Regular"
  ],
  "usageScenarios": [
    { "scenario": "页面级主操作", "variant": "large-深色-default", "when": "登录/提交等整页主行动，用大号深色按钮" },
    { "scenario": "卡片内操作", "variant": "small-深色-default", "when": "卡片底部操作（扫码到库/分单/审核），用小号深色按钮" },
    { "scenario": "次要操作", "variant": "large-浅色-default / small-浅色-default", "when": "与主按钮并列的次级行动，用浅色按钮" },
    { "scenario": "清除/取消", "variant": "large-清除-default", "when": "重置/取消类操作，用清除风格按钮" },
    { "scenario": "文字按钮（更多）", "variant": "small-文字-default", "when": "「更多」等弱操作，用无底色文字按钮" }
  ],
  "states": [
    { "state": "default", "trigger": "默认", "class": "btn btn--primary（大号加 .btn--lg，小号加 .btn--sm）" },
    { "state": "hover", "trigger": "鼠标悬停", "class": "btn--primary（:hover 背景切换 vi-3 #009093）" },
    { "state": "active", "trigger": "按下", "class": "btn（:active transform scale(0.97)）" },
    { "state": "disabled", "trigger": "禁用", "class": "btn--disabled（文字/图标 opacity 40%，cursor not-allowed）" }
  ],
  "cssClasses": ["btn", "btn--lg", "btn--md", "btn--sm", "btn--primary", "btn--light", "btn--light-solid", "btn--clear", "btn--text", "btn--disabled", "btn--block"],
  "exampleRefs": ["examples/login.html", "examples/demo-list.html", "preview/component-button.html"]
}
